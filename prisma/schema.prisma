generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String         @id @db.Uuid
  email              String         @unique
  username           String         @unique
  dni                String?        @unique
  passwordHash       String         @map("password_hash")
  fullName           String         @map("full_name")
  branchName         String?        @map("branch_name")
  photoUrl           String?        @map("photo_url")
  isAdmin            Boolean        @map("is_admin")
  isActive           Boolean        @map("is_active")
  mustChangePassword Boolean        @map("must_change_password")
  createdAt          DateTime       @map("created_at")
  updatedAt          DateTime       @map("updated_at")
  rankings           SalesRanking[]

  @@map("users")
}

model SalesRanking {
  id           String   @id @db.Uuid
  periodLabel  String   @map("period_label")
  rankPosition Int      @map("rank_position")
  userId       String?  @map("user_id") @db.Uuid
  fullName     String   @map("full_name")
  branchName   String?  @map("branch_name")
  photoUrl     String?  @map("photo_url")
  salesCount   Int      @map("sales_count")
  pendingSales Int      @default(0) @map("pending_sales")
  rejectedSales Int     @default(0) @map("rejected_sales")
  note         String?
  isActive     Boolean  @map("is_active")
  createdAt    DateTime @map("created_at")
  updatedAt    DateTime @map("updated_at")
  user         User?    @relation(fields: [userId], references: [id])

  @@map("sales_ranking")
}

model TrainingMedia {
  id          String   @id @db.Uuid
  title       String
  description String?
  mediaType   String   @map("media_type")
  fileUrl     String   @map("file_url")
  fileKey     String?  @map("file_key")
  weekLabel   String?  @map("week_label")
  isFeatured  Boolean  @default(false) @map("is_featured")
  isActive    Boolean  @map("is_active")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@map("training_media")
}
