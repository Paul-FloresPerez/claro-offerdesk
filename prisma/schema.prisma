generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String         @id @db.Uuid
  email              String         @unique
  username           String         @unique
  dni                String?        @unique
  passwordHash       String         @map("password_hash")
  fullName           String         @map("full_name")
  branchName         String?        @map("branch_name")
  photoUrl           String?        @map("photo_url")
  isAdmin            Boolean        @map("is_admin")
  isActive           Boolean        @map("is_active")
  mustChangePassword Boolean        @map("must_change_password")
  createdAt          DateTime       @map("created_at")
  updatedAt          DateTime       @map("updated_at")
  rankings           SalesRanking[]

  @@map("users")
}

model SalesRanking {
  id           String   @id @db.Uuid
  periodLabel  String   @map("period_label")
  rankPosition Int      @map("rank_position")
  userId       String?  @map("user_id") @db.Uuid
  fullName     String   @map("full_name")
  branchName   String?  @map("branch_name")
  photoUrl     String?  @map("photo_url")
  salesCount   Int      @map("sales_count")
  note         String?
  isActive     Boolean  @map("is_active")
  createdAt    DateTime @map("created_at")
  updatedAt    DateTime @map("updated_at")
  user         User?    @relation(fields: [userId], references: [id])

  @@map("sales_ranking")
}

model TrainingMedia {
  id          String   @id @db.Uuid
  title       String
  description String?
  mediaType   String   @map("media_type")
  fileUrl     String   @map("file_url")
  fileKey     String?  @map("file_key")
  weekLabel   String?  @map("week_label")
  isActive    Boolean  @map("is_active")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@map("training_media")
}

model Promotion {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique
  title           String
  category        String?
  description     String?
  price           String?
  benefits        Json?
  conditions      Json?
  validity        String?
  imageUrl        String?  @map("image_url")
  fileKey         String?  @map("file_key")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  status          String   @default("material-oficial")
  detailPrice     String?  @map("detail_price")
  speed           String?
  technologies    String[] @default([])
  appliesTo       String[] @default([]) @map("applies_to")
  restrictions    String[] @default([])
  validations     String[] @default([])
  salesPhrase     String?  @map("sales_phrase")
  cityImageUrl    String?  @map("city_image_url")
  additionalMedia Json?    @map("additional_media")
  variants        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("promotions")
}
